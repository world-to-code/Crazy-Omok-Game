# 오목 서버 환경 변수
# 이 파일을 .env 로 복사해서 값을 채우세요.  (cp .env.example .env)
# 실제 환경 변수가 .env 값보다 우선합니다. .env 는 git 에 올리지 마세요.

# 서버 바인딩 주소 (기본 0.0.0.0 = 모든 인터페이스)
OMOK_BIND=0.0.0.0

# 서버 리슨 포트 (배포 시 80).
# 주의: 80 번 포트는 root 권한 또는 setcap 이 필요합니다.
#   sudo setcap 'cap_net_bind_service=+ep' ./target/release/omok-server
OMOK_PORT=80

# 초대 링크에 쓸 공개 호스트/IP (배포 서버의 공인 IP 또는 도메인).
# 미설정 시 자동 감지된 LAN IP 를 사용합니다.
OMOK_PUBLIC_HOST=43.202.33.212

# 초대 링크에 쓸 공개 포트 (미설정 시 OMOK_PORT 사용).
# 80/443 이면 링크에서 포트가 생략됩니다. (예: http://43.202.33.212/?join=ABC123)
OMOK_PUBLIC_PORT=80

# 빌드된 프론트(dist) 경로 (server 디렉터리 기준 기본값 ../web/dist)
OMOK_WEB_DIR=../web/dist
